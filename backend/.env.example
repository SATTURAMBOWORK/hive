# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/apthive

# ── Auth ──────────────────────────────────────────────────────
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Key required when registering a super_admin account
SUPER_ADMIN_SIGNUP_KEY=replace_with_a_secret_key

# ── Frontend origin (used for CORS) ───────────────────────────
# Set to your deployed frontend URL — no trailing slash
CLIENT_ORIGIN=https://your-frontend-domain.com

# ── Cloudinary (image uploads) ────────────────────────────────
# Get from cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (nodemailer) ────────────────────────────────────────
# Use an app password if using Gmail (not your normal password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="AptHive <your_email@gmail.com>"

# ── Redis (optional but recommended in production) ────────────
# Required for PM2 cluster mode — without it, socket events
# won't reach clients connected to different processes.
# Get from Redis Cloud or set up your own Redis instance.
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=apthive
REDIS_CACHE_TTL_SECONDS=60
